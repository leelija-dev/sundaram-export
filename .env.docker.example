# Copy to .env.docker before running docker compose:
#   copy .env.docker.example .env.docker
#
# Public URL used by the browser (no trailing slash).
# Rebuild frontend after changing this value.
PUBLIC_SITE_URL=http://localhost

HTTP_PORT=80

# PostgreSQL
POSTGRES_DB=sundaram_export
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

DESK_BASE_URL=http://localhost/desk/
ADMIN_BASE_URL=http://localhost/admin/

# Optional: seed categories/currencies on first container start
SEED_MASTER_ON_START=true

# Email
DEFAULT_FROM_EMAIL=noreply@sundaramexport.com
INQUIRY_NOTIFY_EMAIL=exports@sundaramexport.com
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# Company branding
COMPANY_NAME=Sundaram Export
COMPANY_LOGO=config/images/company_logo.svg
COMPANY_LOGO_TRANSPARENT=config/images/company_logo.svg
COMPANY_CONTACT=8000000000
COMPANY_EMAIL=exports@sundaramexport.com
COMPANY_GSTIN=
COMPANY_TAGLINE=Export of agro commodities, spices & trade goods from India

# Frontend public site copy (baked into the Next.js build)
NEXT_PUBLIC_SITE_EMAIL=exports@sundaramexport.com
NEXT_PUBLIC_SITE_PHONE=+91 22 4000 1200
NEXT_PUBLIC_SITE_PHONE_ALT=+1 (713) 555 0142
NEXT_PUBLIC_SITE_ADDRESS=Sundaram Trade Tower, Bandra Kurla Complex, Mumbai 400051, India
NEXT_PUBLIC_SITE_ADDRESS_SHORT=Mumbai, India
NEXT_PUBLIC_SITE_ADDRESS_US=2400 Port Commerce Parkway, Houston, TX 77029, USA
NEXT_PUBLIC_SITE_FOUNDED_YEAR=1998
