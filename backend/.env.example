DEBUG=True
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Staff URLs (for inquiry notification emails)
DESK_BASE_URL=http://127.0.0.1:8000/desk/
ADMIN_BASE_URL=http://127.0.0.1:8000/admin/

# Comma-separated origins for CORS (Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL database (set USE_POSTGRES=False to fall back to SQLite)
USE_POSTGRES=True
POSTGRES_DB=sundaram_export
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Email — website contact/quote forms notify these addresses
# Without SMTP credentials below, alerts print in the Django runserver terminal
DEFAULT_FROM_EMAIL=noreply@sundaramexport.com
INQUIRY_NOTIFY_EMAIL=exports@sundaramexport.com
# Optional: multiple admins (comma-separated)
# INQUIRY_NOTIFY_EMAILS=exports@sundaramexport.com,sales@yourcompany.com
# Real email (Gmail app password, SendGrid, etc.):
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
