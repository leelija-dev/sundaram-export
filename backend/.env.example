# Copy to .env and adjust for your machine:
#   copy .env.example .env

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — SQLite by default; set USE_POSTGRES=True for PostgreSQL
# USE_POSTGRES=True
# POSTGRES_DB=sundaram_export
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_postgres_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433

# CORS (Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Desk & admin URLs
DESK_BASE_URL=http://127.0.0.1:8000/desk/
ADMIN_BASE_URL=http://127.0.0.1:8000/admin/

# Email
DEFAULT_FROM_EMAIL=noreply@sundaramexport.com
INQUIRY_NOTIFY_EMAIL=exports@sundaramexport.com
# INQUIRY_NOTIFY_EMAILS=exports@sundaramexport.com

# SMTP (optional — leave blank to print emails in the terminal)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# Company branding
COMPANY_NAME=Sundaram Export
COMPANY_LOGO=config/images/company_logo.svg
COMPANY_LOGO_TRANSPARENT=config/images/company_logo.svg
COMPANY_CONTACT=8000000000
COMPANY_EMAIL=exports@sundaramexport.com
