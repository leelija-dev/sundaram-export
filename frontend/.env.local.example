NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Public site URL for SEO (canonical links, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site contact & company (shown in header, footer, about, contact)
NEXT_PUBLIC_SITE_EMAIL=exports@sundaramexport.com
NEXT_PUBLIC_SITE_PHONE=+91 22 4000 1200
NEXT_PUBLIC_SITE_PHONE_ALT=+1 (713) 555 0142
NEXT_PUBLIC_SITE_ADDRESS=Sundaram Trade Tower, Bandra Kurla Complex, Mumbai 400051, India
NEXT_PUBLIC_SITE_ADDRESS_SHORT=Mumbai, India
NEXT_PUBLIC_SITE_ADDRESS_US=2400 Port Commerce Parkway, Houston, TX 77029, USA

# Founded year — used for "Since YYYY" copy; years of experience is derived from this
NEXT_PUBLIC_SITE_FOUNDED_YEAR=1998
# Optional: override displayed years of experience (e.g. 27). Leave unset to auto-calculate from founded year.
# NEXT_PUBLIC_SITE_YEARS_EXPERIENCE=27

# Optional: override Google Maps embed iframe URL (defaults to address-based embed)
# NEXT_PUBLIC_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Optional: media host if different from API origin (defaults to API origin without /api/v1)
# NEXT_PUBLIC_MEDIA_ORIGIN=http://127.0.0.1:8000
